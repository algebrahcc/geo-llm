registry=https://registry.npmmirror.com/
# 将 pnpm 的全局 store 指向项目内部的 .pnpm-store 文件夹
store-dir = ".pnpm-store"

# 依赖安装方式：使用 copy 而不是硬链接
# 这样可以确保拷贝到其他机器时文件完整可用
package-import-method = copy

# 强制提升所有依赖到扁平的 node_modules
# 模拟 npm/yarn 的结构，避免路径解析问题
shamefully-hoist = true

# 严格模式下不检查 peer 依赖版本（避免很多不必要的警告）
strict-peer-dependencies = false

# 自动安装 peer 依赖
auto-install-peers = true

# 解决 windows 路径过长问题（如果文件路径超过 260 字符）
node-linker = hoisted
